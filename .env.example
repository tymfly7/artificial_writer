# Copy this file to ".env" and adjust as needed. The .env file is gitignored.
#
# The offline CLI/GUI work fully free with the default "extractive" summarizer,
# so none of these are required to get started. The multi-tenant web service
# (infra/docker-compose.yml) reads the AW_* vars below; the compose file
# overrides AW_DATABASE_URL / AW_REDIS_URL to point at its own postgres/redis.

# ── Core summarizer ──────────────────────────────────────────────────────────
# Which summarizer to use: extractive | ollama | openai | anthropic
AW_SUMMARIZER=extractive

# Upper bound on characters fed to the summarizer; text is cut back to the last
# full stop, and each backend may apply its own (smaller) token cap on top.
AW_MAX_INPUT_CHARS=80000

# Target number of sentences for the extractive summarizer.
AW_EXTRACTIVE_SENTENCES=5

# Logging level: DEBUG | INFO | WARNING | ERROR
AW_LOG_LEVEL=INFO

# Network timeout (seconds) for fetching articles.
AW_REQUEST_TIMEOUT=30

# Per-backend input caps (estimated tokens; conservative char-based estimate,
# not exact per-model tokenization). Applied under AW_MAX_INPUT_CHARS and cut
# back to the last full stop. Lower them to bound cost / fit smaller contexts.
AW_OLLAMA_MAX_INPUT_TOKENS=8000
AW_OPENAI_MAX_INPUT_TOKENS=12000
AW_ANTHROPIC_MAX_INPUT_TOKENS=24000

# Note: output format (prose | tldr | bullets | eli5 | quotes | tweet | linkedin)
# is chosen per request (API/UI), not via an env var; "prose" is the default.

# ── Free local LLM (Ollama). Install from https://ollama.com, then `ollama pull llama3.2` ─
# Running outside docker, localhost is correct and this is the value used.
AW_OLLAMA_HOST=http://localhost:11434
AW_OLLAMA_MODEL=llama3.2

# Under docker-compose, a container's "localhost" is itself, not the host running
# `ollama serve` -- so the api/worker containers default to host.docker.internal
# instead (see infra/docker-compose.yml). They read THIS var, not AW_OLLAMA_HOST,
# so the localhost default above can't shadow it. Only set this to point the
# containers at a different/remote Ollama; leave it unset for the normal case.
# AW_OLLAMA_HOST_DOCKER=http://host.docker.internal:11434

# ── Optional cloud providers (bring your own key; paid backends, opt-in) ──────
AW_OPENAI_API_KEY=
AW_OPENAI_MODEL=gpt-4o-mini

AW_ANTHROPIC_API_KEY=
AW_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Multi-tenant service layer (web API / worker / scheduler) ────────────────
# Async SQLAlchemy URL for the app; Alembic converts +asyncpg -> +psycopg itself.
# Under docker-compose this is overridden to use the "postgres" service host.
AW_DATABASE_URL=postgresql+asyncpg://aw:aw@localhost:5432/aw

# Redis URL used as the RQ broker + result store (batch jobs, feed polling).
AW_REDIS_URL=redis://localhost:6379/0

# Secret that signs the "aw_session" login cookie. CHANGE THIS in any real deploy.
AW_SESSION_SECRET=change-me

# Tier assigned to newly-registered users.
AW_DEFAULT_TIER=free

# Tier policy (JSON values). Free tiers are limited to the offline/free backends
# and spend nothing; paid tiers unlock the cloud backends up to a daily request
# count and USD cost ceiling.
AW_FREE_BACKENDS=["extractive", "ollama"]
AW_PAID_BACKENDS=["openai", "anthropic"]
AW_TIER_DAILY_REQUEST_CAP={"free": 20, "pro": 500}
AW_TIER_DAILY_COST_CAP_USD={"free": 0.0, "pro": 5.0}

# ── docker-compose Postgres credentials (used by infra/docker-compose.yml) ────
# Keep these in sync with the user/password/db embedded in AW_DATABASE_URL.
POSTGRES_USER=aw
POSTGRES_PASSWORD=aw
POSTGRES_DB=aw
